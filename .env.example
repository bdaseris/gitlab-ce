GITLAB_HOME=/data/gitlab

# IP de la VM hôte : utilisée par les containers de job CI pour résoudre
# gitlab.local (les jobs tournent hors du réseau overlay Swarm)
GITLAB_HOST_IP=192.168.1.10

# SMTP (valeurs non sensibles — le mot de passe est géré via Docker secret)
SMTP_ADDRESS=mta.example.com
SMTP_PORT=587
SMTP_USER_NAME="GitLab Notifier <gitlab-info@example.com>"
SMTP_DOMAIN=example.com
